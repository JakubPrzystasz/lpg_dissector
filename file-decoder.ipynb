   "source": [
    "i = 0\n",
    "n = len(out_tail)\n",
    "data = out_tail\n",
    "while i < n:\n",
    "    # detect timestamp (00 00 xx xx pattern)\n",
    "    if i + 4 <= n and data[i] == 0x00 and data[i+1] == 0x00:\n",
    "        ts = int.from_bytes(data[i:i+4], \"big\")\n",
    "        print(f\"\\nTIMESTAMP: {ts}\")\n",
    "        i += 4\n",
    "\n",
    "    # parse TLV fields\n",
    "    while i + 2 <= n:\n",
    "        t = data[i]\n",
    "        l = data[i+1]\n",
    "\n",
    "        # sanity check\n",
    "        if l > 32 or i + 2 + l > n:\n",
    "            break\n",
    "\n",
    "        v = data[i+2:i+2+l]\n",
    "\n",
    "        print(f\"  TYPE=0x{t:02X} LEN={l} VALUE={v.hex()}\")\n",
    "\n",
    "        i += 2 + l\n",
    "\n",
    "        # heuristics: stop block if next looks like timestamp\n",
    "        if i + 4 <= n and data[i] == 0x00 and data[i+1] == 0x00:\n",
    "            break"
   ]
