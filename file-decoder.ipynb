   "source": [
    "# Define signals: (name, start_byte, type, optional scale)\n",
    "signals = [\n",
    "    (\"map\", 0x0C, \"uint16_be\", 0.01),\n",
    "    (\"lpg_bar\", 0x0F, \"uint16\", 0.01),\n",
    "    (\"lpg_temp\", 0x11, \"uint16\", 1),\n",
    "    (\"red_temp\", 0x13, \"uint16\", 1),\n",
    "    (\"internal_temp\", 0x15, \"uint8\", 1),\n",
    "    (\"RPM\", 0x16, \"uint16_be\", 1),\n",
    "    (\"battery_v\", 0x18, \"uint16_be\", 0.001),\n",
    "    (\"load\", 0x54, \"uint16\", 1),\n",
    "    (\"PCM_real\", 0x4, \"uint16_be\", 0.005), \n",
    "    (\"PCM\", 0x8, \"uint16_be\", 0.005), \n",
    "    (\"pb_1\", 0x32, \"uint16_be\", 0.005), \n",
    "    (\"pb_2\", 0x36, \"uint16_be\", 0.005), \n",
    "    (\"pb_3\", 0x3A, \"uint16_be\", 0.005), \n",
    "    (\"pb_4\", 0x3E, \"uint16_be\", 0.005), \n",
    "    (\"lpg_1\", 0x42, \"uint16_be\", 0.005), \n",
    "    (\"lpg_2\", 0x46, \"uint16_be\", 0.005), \n",
    "    (\"lpg_3\", 0x4A, \"uint16_be\", 0.005), \n",
    "    (\"lpg_4\", 0x4E, \"uint16_be\", 0.005), \n",
    "]\n",
    "\n",
    "decoded_data = []\n",
    "for node in nodes:\n",
    "    frame = {}\n",
    "    for name, start, dtype, scale in signals:\n",
    "        if dtype == \"uint16\":\n",
    "            value = struct.unpack(\"<H\", node[start:start+2])[0]\n",
    "        elif dtype == \"int16\":\n",
    "            value = struct.unpack(\"<h\", node[start:start+2])[0]\n",
    "        elif dtype == \"uint16_be\":\n",
    "            value = struct.unpack(\">H\", node[start:start+2])[0]\n",
    "        elif dtype == \"uint8\":\n",
    "            value = struct.unpack(\"<B\", node[start:start+1])[0]\n",
    "        elif dtype == \"int8\":\n",
    "            value = struct.unpack(\"<b\", node[start:start+1])[0]\n",
    "        elif dtype == \"uint32\":\n",
    "            value = struct.unpack(\"<I\", node[start:start+4])[0]\n",
    "        elif dtype == \"int32\":\n",
    "            value = struct.unpack(\"<i\", node[start:start+4])[0]\n",
    "        else:\n",
    "            raise ValueError(f\"Unsupported dtype: {dtype}\")\n",
    "        \n",
    "        frame[name] = round(value * scale, 2)\n",
    "    decoded_data.append(frame)\n",
    "\n",
    "df = pd.DataFrame(decoded_data)\n",
    "pd.set_option('display.max_colwidth', None)\n",
    "display(df)"
   ]
  },
