    "from pathlib import Path\n",
    "import struct\n",
    "import struct\n",
    "import pandas as pd\n",
    "\n",
    "#file_path = Path(\"gaz_i_benzyna.osc\")  138,199 bytes\n",
    "#file_path = Path(\"not-running-ign.osc\") #Bytes to EOF:     6,343 bytes\n",
    "#file_path = Path(\"not-running.osc\") #Bytes to EOF:     6,343 bytes\n",
    "file_path = Path(\"running-no-obd.osc\") #Bytes to EOF:     6,343 bytes\n",
    "\n",
    "file_size = file_path.stat().st_size\n",
    "\n",
    "with open(file_path, \"rb\") as f:\n",
    "    f.seek(0xD5C)\n",
    "    data = f.read()\n",
    "\n",
    "frame_size = 0x6A\n",
    "\n",
    "node_indices = [\n",
    "    i\n",
    "    for i in range(0, len(data), frame_size)\n",
    "    if len(data[i:i+frame_size]) == frame_size and data[i:i+4] == b'\\x80\\x80\\x80\\x80'\n",
    "]\n",
    "nodes = [
    data[i:i+frame_size]
    for i in range(0, len(data), frame_size)
    if len(data[i:i+frame_size]) == frame_size and data[i:i+4] == b'\x80\x80\x80\x80'
    ]\n",
    "last_node_end_in_data = node_indices[-1] + frame_size if node_indices else 0\n",
    "\n",
    "# Everything after the last node\n",
    "tail = data[last_node_end_in_data:]\n",
    "\n",
    "\n",
    "def print_node_hex(nodes, node_id):\n",
    "    if node_id < 0 or node_id >= len(nodes):\n",
    "        print(\"Invalid node id\")\n",
    "        return\n",
    "\n",
    "    node = nodes[node_id]\n",
    "    print(f\"Node {node_id} ({len(node)} bytes):\")\n",
    "    print(node.hex(\" \"))"
   ]
  },
