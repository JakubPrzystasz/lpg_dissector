   "source": [
    "# OBD PID definitions\n",
    "OBD_PIDS = {\n",
    "    0x04: (\"Engine Load\", lambda v: v[0] * 100 / 255, \"%\"),\n",
    "    0x05: (\"Coolant Temp\", lambda v: v[0] - 40, \"°C\"),\n",
    "    0x06: (\"STFT Bank1\", lambda v: (v[0] - 128) * 100 / 128, \"%\"),\n",
    "    0x07: (\"LTFT Bank1\", lambda v: (v[0] - 128) * 100 / 128, \"%\"),\n",
    "    0x08: (\"STFT Bank2\", lambda v: (v[0] - 128) * 100 / 128, \"%\"),\n",
    "    0x09: (\"LTFT Bank2\", lambda v: (v[0] - 128) * 100 / 128, \"%\"),\n",
    "    0x0A: (\"Fuel Pressure\", lambda v: v[0] * 3, \"kPa\"),\n",
    "    0x0B: (\"MAP\", lambda v: v[0], \"kPa\"),\n",
    "    0x0C: (\"RPM\", lambda v: ((v[0] << 8) + v[1]) / 4 if len(v) >= 2 else None, \"rpm\"),\n",
    "    0x0D: (\"Vehicle Speed\", lambda v: v[0], \"km/h\"),\n",
    "    0x0E: (\"Ignition Timing\", lambda v: v[0] / 2 - 64, \"deg\"),\n",
    "    0x0F: (\"Intake Temp\", lambda v: v[0] - 40, \"°C\"),\n",
    "    0x10: (\"MAF\", lambda v: ((v[0] << 8) + v[1]) / 100 if len(v) >= 2 else None, \"g/s\"),\n",
    "    0x11: (\"Throttle\", lambda v: v[0] * 100 / 255, \"%\"),\n",
    "}\n",
    "\n",
    "i = 0\n",
    "n = len(out_tail)\n",
    "data = out_tail\n",
    "\n",
    "frame_count = 0\n",
    "MAX_FRAMES = 100\n",
    "\n",
    "while i < n and frame_count < MAX_FRAMES:\n",
    "\n",
    "    # detect timestamp\n",
    "    if i + 4 <= n and data[i] == 0x00 and data[i+1] == 0x00:\n",
    "        ts = int.from_bytes(data[i:i+4], \"big\")\n",
    "        print(f\"\\nTIMESTAMP: {ts}\")\n",
    "        i += 4\n",
    "        frame_count += 1\n",
    "\n",
    "    while i + 2 <= n:\n",
    "\n",
    "        t = data[i]\n",
    "        l = data[i+1]\n",
    "\n",
    "        if l > 32 or i + 2 + l > n:\n",
    "            break\n",
    "\n",
    "        v = data[i+2:i+2+l]\n",
    "\n",
    "        line = f\"  TYPE=0x{t:02X} LEN={l} VALUE={v.hex()}\"\n",
    "\n",
    "        # OBD decode\n",
    "        if t in OBD_PIDS and len(v) > 0:\n",
    "            name, formula, unit = OBD_PIDS[t]\n",
    "\n",
    "            try:\n",
    "                real_val = formula(v)\n",
    "                line += f\"  -> {name}: {real_val:.2f} {unit}\"\n",
    "            except:\n",
    "                pass\n",
    "\n",
    "        print(line)\n",
    "\n",
    "        i += 2 + l\n",
    "\n",
    "        # stop block if next looks like timestamp\n",
    "        if i + 4 <= n and data[i] == 0x00 and data[i+1] == 0x00:\n",
    "            break\n",
    "\n",
    "    "
   ]
